{
  "name": "lovable-migrate",
  "version": "0.1.0",
  "description": "Migration engine for Lovable.dev exported projects",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "lovable-migrate": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --project tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:snapshots": "vitest run -u"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "adm-zip": "^0.5.10",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  }
}
