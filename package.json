{
  "name": "lovable-migrate",
  "version": "0.3.5",
  "description": "CLI migration engine for Lovable.dev projects — auto-detects stack, generates Dockerfile, GitHub Actions CI/CD, and remote deploy plan. Zero original-project modification.",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "lovable-migrate": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "examples/generated-workflows/"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "lovable",
    "lovable.dev",
    "migration",
    "deploy",
    "supabase",
    "docker",
    "dockerfile",
    "github-actions",
    "cli",
    "react",
    "vite",
    "self-hosted"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dynhosilva/migrator.git"
  },
  "homepage": "https://github.com/dynhosilva/migrator#readme",
  "bugs": {
    "url": "https://github.com/dynhosilva/migrator/issues"
  },
  "scripts": {
    "build": "tsc",
    "build:clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --project tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:snapshots": "vitest run -u",
    "test:dist": "vitest run test/packaging/",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:watch": "vitest --config vitest.e2e.config.ts",
    "preview:html": "ts-node scripts/generate-html-preview.ts",
    "capture": "ts-node --transpile-only scripts/capture.ts",
    "prepublishOnly": "npm run typecheck && npm test && npm run build:clean"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@supabase/supabase-js": "^2.105.4",
    "adm-zip": "^0.5.10",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "fastify": "^5.8.5",
    "ink": "^3.2.0",
    "react": "^17.0.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^20.14.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^17.0.91",
    "gif-encoder-2": "^1.0.5",
    "ink-testing-library": "^2.1.0",
    "pngjs": "^7.0.0",
    "puppeteer-core": "^24.43.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  }
}
