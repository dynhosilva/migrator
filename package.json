{
  "name": "lovable-migrate",
  "version": "0.1.0",
  "description": "Migration engine for Lovable.dev exported projects — analyze, plan, validate, migrate, deploy",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "lovable-migrate": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "lovable",
    "migration",
    "deploy",
    "supabase",
    "docker",
    "cli",
    "self-hosted"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/lovable-migrate.git"
  },
  "homepage": "https://github.com/your-org/lovable-migrate#readme",
  "bugs": {
    "url": "https://github.com/your-org/lovable-migrate/issues"
  },
  "scripts": {
    "build": "tsc",
    "build:clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --project tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:snapshots": "vitest run -u",
    "test:dist": "vitest run test/packaging/",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "adm-zip": "^0.5.10",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "fastify": "^5.8.5",
    "ink": "^3.2.0",
    "react": "^17.0.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^20.14.0",
    "@types/react": "^17.0.91",
    "ink-testing-library": "^2.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  }
}
