exports[`POST /remote — react-vite > data normalizada corresponde ao snapshot 1`] = `
{
  "deployCompatible": true,
  "deployStrategy": "static",
  "executionSteps": [
    {
      "command": "ssh ubuntu@your-server.example.com -i ~/.ssh/id_rsa "mkdir -p /opt/app/docker /opt/app/env"",
      "description": "Cria estrutura de diretórios no servidor remoto",
      "id": "create-remote-dirs",
      "remote": true,
      "risk": "low",
    },
    {
      "command": "rsync -avz -e "ssh -i ~/.ssh/id_rsa" docker/Dockerfile docker/docker-compose.yml docker/.dockerignore env/.env.example env/.env.production.example reports/migration-summary.json ubuntu@your-server.example.com:/opt/app/",
      "description": "Transfere 6 arquivo(s) para o servidor remoto",
      "id": "transfer-files",
      "remote": false,
      "requires": [
        "create-remote-dirs",
      ],
      "risk": "medium",
    },
    {
      "command": "ssh ubuntu@your-server.example.com -i ~/.ssh/id_rsa "cd /opt/app && docker build -f docker/Dockerfile -t react-vite:latest ."",
      "description": "Constrói imagem Docker no servidor remoto",
      "id": "docker-build-remote",
      "remote": true,
      "requires": [
        "transfer-files",
      ],
      "risk": "medium",
    },
    {
      "command": "ssh ubuntu@your-server.example.com -i ~/.ssh/id_rsa "cd /opt/app && docker compose -f docker/docker-compose.yml up -d"",
      "description": "Inicia os containers via Docker Compose",
      "id": "docker-compose-up",
      "remote": true,
      "requires": [
        "docker-build-remote",
      ],
      "risk": "high",
    },
    {
      "command": "ssh ubuntu@your-server.example.com -i ~/.ssh/id_rsa "curl -sf http://localhost:80/ && echo OK"",
      "description": "Verifica que a aplicação está respondendo na porta esperada",
      "id": "verify-health",
      "remote": true,
      "requires": [
        "docker-compose-up",
      ],
      "risk": "low",
    },
  ],
  "hostCompatible": true,
  "issues": [
    {
      "code": "SSH_HOST_NOT_CONFIGURED",
      "message": "Host SSH não configurado — usando placeholder padrão.",
      "severity": "warning",
      "suggestion": "Forneça o hostname ou endereço IP real do servidor de destino.",
    },
  ],
  "outputDir": "<OUTPUT_DIR>",
  "preparedAt": "<TIMESTAMP>",
  "projectName": "react-vite",
  "readiness": "ready-with-warnings",
  "remotePath": "/opt/app",
